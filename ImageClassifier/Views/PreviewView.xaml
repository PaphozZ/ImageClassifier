<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ImageClassifier.ViewModel.ViewModels;assembly=ImageClassifier.ViewModel"
             xmlns:local="clr-namespace:ImageClassifier.Views"
             x:Class="ImageClassifier.Views.PreviewView"
             x:DataType="vm:PreviewViewModel">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <local:ImageListView Grid.Column="0" />
        <local:SidePanelView Grid.Column="1" />

        <local:FullscreenView Grid.ColumnSpan="2" />
        <local:TrainMenuView Grid.ColumnSpan="2" />
        <local:PredictMenuView Grid.ColumnSpan="2" />
    </Grid>
</ContentView>
